# Copy to .env.local and fill in from your Supabase project (Settings > API Keys).
# Use the NEW key format (sb_publishable_...), not the legacy anon key.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — used by the invite-man Edge Function. NEVER prefix with VITE_.
# Set as a function secret via:
#   supabase secrets set SUPABASE_SECRET_KEY=sb_secret_xxx
# Do not put this in .env.local checked into git.
